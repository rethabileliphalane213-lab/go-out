

<!DOCTYPE html>
<html>
    <head>
         <link rel="stylesheet" href="/styles.css">
    </head>
    <body>
        <div class="main">
             <form method="post" action="/username">
                <h1>How should i call or Text you</h1>
            <div class="container">
                <label for="phone">Phone Number</label>
                <input type="text" id="phone" name="phone" placeholder="0716881860"/>

            </div>
            <div class="time">
                <label for="name">Name</label>
                <input type="text" name="name" id="name">
            </div>

            <button type="submit">Finalise</button>
        </form>

         <audio  id="music" preload="auto" loop>
        <source src="/seven-years-old.mp3" type="audio/mpeg" loop>
       </audio>

            </div>
       <p id="hope"></p>
            </div>
        </div>
    </body>
      <script>
 const music = document.getElementById("music");
  
  // Only start music if it wasn't playing before
  if (sessionStorage.getItem("music-on") !== "true") {
    // First time - do nothing. Music starts only on Yes click
    music.pause();
  } else {
    // Music was playing - resume from saved time
    music.volume = 0.1;
    music.loop = true;
    const savedTime = parseFloat(sessionStorage.getItem("music-time") || 0);
    
    // Wait for audio to load, then jump to saved time
    music.addEventListener("canplay", () => {
      music.currentTime = savedTime;
      music.play().catch(() => {});
    }, { once: true });
    
    // Keep saving current time every second
    setInterval(() => {
      if (!music.paused) {
        sessionStorage.setItem("music-time", music.currentTime);
      }
    }, 1000);
  }
     
    </script>
</html>